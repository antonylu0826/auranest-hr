generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Per-role baseline access policy evaluated before explicit permission grants.
/// DENY_ALL = no access unless explicitly granted; READ_ALL = all *_READ auto-pass;
/// ALLOW_ALL = bypass permission checks (use for power roles).
enum PermissionPolicy {
  DENY_ALL
  READ_ALL
  ALLOW_ALL
}

/// Fine-grained permission tokens attached to Role records.
/// Base set: USERS_* / API_KEYS_* (shared by all apps).
/// HR set: HR_EMPLOYEE_* / HR_ORG_* / HR_SHIFT_* / HR_JOB_* / HR_DEPENDENT_*.
enum Permission {
  // ── Base permissions ───────────────────────────────────
  USERS_READ
  USERS_CREATE
  USERS_UPDATE
  USERS_DELETE
  API_KEYS_READ
  API_KEYS_CREATE
  API_KEYS_DELETE
  // ── HR: Employees ─────────────────────────────────────
  HR_EMPLOYEE_READ
  HR_EMPLOYEE_CREATE
  HR_EMPLOYEE_UPDATE
  HR_EMPLOYEE_DELETE
  // ── HR: Org Units ─────────────────────────────────────
  HR_ORG_READ
  HR_ORG_CREATE
  HR_ORG_UPDATE
  HR_ORG_DELETE
  // ── HR: Shift Types ───────────────────────────────────
  HR_SHIFT_READ
  HR_SHIFT_CREATE
  HR_SHIFT_UPDATE
  HR_SHIFT_DELETE
  // ── HR: Job Titles ────────────────────────────────────
  HR_JOB_READ
  HR_JOB_CREATE
  HR_JOB_UPDATE
  HR_JOB_DELETE
  // ── HR: Employee Dependents ───────────────────────────
  HR_DEPENDENT_READ
  HR_DEPENDENT_CREATE
  HR_DEPENDENT_UPDATE
  HR_DEPENDENT_DELETE
}

/// Named access role assignable to users and API keys. ADMIN and USER are system-locked.
/// @internal
model Role {
  id               String           @id @default(cuid())
  /// Unique machine name, e.g. "ADMIN", "USER", "HR_MANAGER".
  name             String           @unique
  /// Human-readable label shown in UI.
  displayName      String           @map("display_name")
  permissionPolicy PermissionPolicy @default(DENY_ALL) @map("permission_policy")
  /// System roles (ADMIN/USER) cannot be deleted.
  isSystem         Boolean          @default(false) @map("is_system")
  /// Assigned automatically to new users when no role is specified.
  isDefault        Boolean          @default(false) @map("is_default")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  permissions      RolePermission[]
  userRoles        UserRole[]
  apiKeys          ApiKey[]

  @@map("roles")
}

/// Join table between Role and Permission enum values. @internal
model RolePermission {
  id         String     @id @default(cuid())
  roleId     String     @map("role_id")
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([roleId, permission])
  @@map("role_permissions")
}

/// Junction table supporting many-to-many User ↔ Role assignment. @internal
model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Biological sex of an employee, used for demographic reporting.
enum Gender {
  MALE
  FEMALE
  OTHER
}

/// Employee's contractual arrangement.
/// FULL_TIME: standard 40-hour week; PART_TIME: reduced hours; CONTRACT: fixed-term; INTERN: internship.
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

/// Current employment lifecycle state.
/// ACTIVE: currently employed; RESIGNED: voluntary separation by employee;
/// TERMINATED: company-initiated separation; ON_LEAVE: unpaid leave with job guarantee.
enum EmploymentStatus {
  ACTIVE
  RESIGNED
  TERMINATED
  ON_LEAVE
}

/// Hierarchical level of an organisational unit.
/// COMPANY > DIVISION > DEPARTMENT > TEAM
enum OrgUnitLevel {
  COMPANY
  DIVISION
  DEPARTMENT
  TEAM
}

/// Job title / position classification within the organisation.
/// Assigned to employees to identify their role level and function.
model JobTitle {
  id          String            @id @default(cuid())
  /// Display name, e.g. "Senior Software Engineer". Must be unique.
  name        String            @unique
  /// Short code for reporting, e.g. "SSE". Must be unique.
  code        String            @unique
  /// Functional department this title belongs to, e.g. "Engineering".
  department  String?
  /// Compensation grade / band, e.g. "L5". Used for salary banding.
  grade       String?
  /// Inactive titles are hidden from new assignments but retained for history.
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  employees   EmployeeProfile[]

  @@index([isActive])
  @@map("job_titles")
}

/// Shift scheduling pattern.
/// FIXED: same start/end time every workday; ROTATING: cyclical work/rest pattern (e.g. 4 on 2 off).
enum ShiftCategory {
  FIXED
  ROTATING
}

/// Machine-to-machine API key for external integrations (n8n, AI agents).
/// Created by ADMIN only. Raw key is shown once at creation and never stored. @internal
model ApiKey {
  id         String    @id @default(cuid())
  /// Human-readable label, e.g. "n8n production" or "AI agent read-only".
  name       String
  /// First 16 chars of the raw key, shown in lists for identification (e.g. "an_live_a1b2c3d4").
  prefix     String
  /// SHA-256 hash of the raw key. The raw key is never persisted.
  hashedKey  String    @unique @map("hashed_key")
  /// Role this key authenticates as when calling the API.
  roleId     String    @map("role_id")
  role       Role      @relation(fields: [roleId], references: [id])
  /// Module-level scopes, e.g. ["users:read","employees:*"]. "*" = all scopes. Empty = deny all.
  scopes     String[]
  /// Requests per minute. null = system default (60).
  rateLimit  Int?      @map("rate_limit")
  /// Whether this key can be used. Set false to revoke without deleting.
  isActive   Boolean   @default(true) @map("is_active")
  /// Optional expiry. null = never expires.
  expiresAt  DateTime? @map("expires_at")
  /// Email of the ADMIN who created this key. Snapshot string, no FK.
  createdBy  String?   @map("created_by")
  /// Timestamp of last successful authentication with this key.
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("api_keys")
}

/// System user account. Used for authentication in local-auth mode.
/// Linked 1-to-1 with EmployeeProfile via userId (optional — an employee may exist before an account is created).
model User {
  id              String           @id @default(cuid())
  /// Login email, must be unique across the system.
  email           String           @unique
  password        String
  /// Display name shown in UI; optional.
  name            String?
  /// Soft-disable without deleting — preserves audit history.
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  employeeProfile EmployeeProfile?
  userRoles       UserRole[]

  @@map("users")
}

/// Shift (work schedule) template defining working hours and cycle.
/// Assigned to employees to determine their daily work pattern.
model ShiftType {
  id                String        @id @default(cuid())
  /// Human-readable name, e.g. "Morning Shift". Must be unique.
  name              String        @unique
  /// Short uppercase identifier, e.g. "MORNING". Must be unique.
  code              String        @unique
  category          ShiftCategory @default(FIXED)
  /// Scheduled work start time in HH:mm (24-hour). Null = flexible.
  workStart         String?       @map("work_start")
  /// Scheduled work end time in HH:mm (24-hour). Null = flexible.
  workEnd           String?       @map("work_end")
  /// Break period start in HH:mm. Null = no fixed break.
  breakStart        String?       @map("break_start")
  /// Break period end in HH:mm.
  breakEnd          String?       @map("break_end")
  /// FIXED only. Whether public holidays are automatically treated as rest days.
  observeHolidays   Boolean       @default(true) @map("observe_holidays")
  /// FIXED only. Earliest allowed clock-in time for flex start (HH:mm).
  flexEarliestStart String?       @map("flex_earliest_start")
  /// FIXED only. Latest allowed clock-in time for flex start (HH:mm).
  flexLatestStart   String?       @map("flex_latest_start")
  /// ROTATING only. Number of consecutive workdays in one cycle, e.g. 4.
  workDaysInCycle   Int?          @map("work_days_in_cycle")
  /// ROTATING only. Number of consecutive rest days in one cycle, e.g. 2.
  restDaysInCycle   Int?          @map("rest_days_in_cycle")
  /// ROTATING only. Reference date to align the cycle phase for all employees.
  cycleAnchorDate   DateTime?     @map("cycle_anchor_date")
  /// Inactive shifts are hidden from selection but retained for historical records.
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  employees         EmployeeProfile[]

  @@map("shift_types")
}

/// Node in the company organisational hierarchy.
/// Forms a tree via parent/children self-relation (unlimited depth).
model OrgUnit {
  id        String       @id @default(cuid())
  /// Display name of the unit, e.g. "Engineering Department".
  name      String
  level     OrgUnitLevel
  /// Optional employee who leads this unit. FK to EmployeeProfile (nullable).
  headId    String?      @map("head_id")
  head      EmployeeProfile?  @relation("OrgUnitHead", fields: [headId], references: [id], onDelete: SetNull)
  /// Parent unit in the hierarchy. Null = root node (typically the company itself).
  parentId  String?      @map("parent_id")
  parent    OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrgUnit[]    @relation("OrgUnitTree")
  employees EmployeeProfile[] @relation("OrgUnitMembers")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("org_units")
}

/// Family relationship of a dependent to an employee.
enum DependentRelationship {
  /// Legally married partner.
  SPOUSE
  /// Biological or adopted child.
  CHILD
  /// Biological or adoptive parent.
  PARENT
  /// Brother or sister.
  SIBLING
  /// Any other relationship not listed above.
  OTHER
}

/// Core HR record for every person employed by the organisation.
/// May exist before a system User account is created (userId is optional).
model EmployeeProfile {
  id                    String           @id @default(cuid())
  /// Company-assigned employee ID, e.g. "EMP-001". Must be unique.
  employeeNumber        String           @unique @map("employee_number")
  /// Full legal name.
  name                  String
  /// Linked system account. Null until IT creates and links a User account.
  userId                String?          @unique @map("user_id")
  user                  User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Assigned organisational unit. Null if unassigned.
  orgUnitId             String?          @map("org_unit_id")
  orgUnit               OrgUnit?         @relation("OrgUnitMembers", fields: [orgUnitId], references: [id], onDelete: SetNull)
  ledOrgUnits           OrgUnit[]        @relation("OrgUnitHead")
  /// Assigned job title. Identifies employee's role level and function.
  jobTitleId            String?          @map("job_title_id")
  jobTitle              JobTitle?        @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  /// Assigned shift template. Determines daily work schedule.
  shiftTypeId           String?          @map("shift_type_id")
  shiftType             ShiftType?       @relation(fields: [shiftTypeId], references: [id], onDelete: SetNull)
  /// Government-issued national identification number.
  nationalId            String?          @map("national_id")
  gender                Gender?
  /// Date of birth in YYYY-MM-DD (stored as date-only, no timezone).
  birthDate             DateTime?        @map("birth_date") @db.Date
  /// ISO 3166-1 alpha-2 country code, default "TW".
  nationality           String?          @default("TW")
  phone                 String?
  address               String?
  /// Name of the person to contact in an emergency.
  emergencyContactName  String?          @map("emergency_contact_name")
  emergencyContactPhone String?          @map("emergency_contact_phone")
  /// Date the employee joined the company (YYYY-MM-DD).
  hireDate              DateTime?        @map("hire_date") @db.Date
  employmentType        EmploymentType   @default(FULL_TIME) @map("employment_type")
  employmentStatus      EmploymentStatus @default(ACTIVE) @map("employment_status")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  dependents            EmployeeDependent[]

  @@index([employeeNumber])
  @@index([employmentStatus])
  @@index([orgUnitId])
  @@map("employee_profiles")
}

/// A family member or dependent registered under an employee's HR record.
model EmployeeDependent {
  id           String                @id @default(cuid())
  /// FK to the owning employee profile.
  employeeId   String                @map("employee_id")
  employee     EmployeeProfile       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  /// Full legal name of the dependent.
  name         String
  relationship DependentRelationship
  gender       Gender?
  /// Date of birth in YYYY-MM-DD (date-only, no timezone).
  birthDate    DateTime?             @map("birth_date") @db.Date
  /// National identification number; optional.
  nationalId   String?               @map("national_id")
  phone        String?
  /// Inactive records are hidden from normal views but retained for history.
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@index([employeeId])
  @@map("employee_dependents")
}
